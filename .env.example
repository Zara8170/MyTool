# ──────────────────────────────────────────────────────────────
# 데이터베이스 (Supabase)
# Project Settings → Database → Connection string 에서 복사
# ──────────────────────────────────────────────────────────────

# 런타임용: Supabase Supavisor pooler (Transaction mode, port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# 마이그레이션 전용: Supabase direct connection (port 5432)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ──────────────────────────────────────────────────────────────
# JWT / 인증 (openssl rand -base64 48 로 생성)
# ──────────────────────────────────────────────────────────────

JWT_SECRET=replace-with-random-32-plus-character-string-from-openssl
AUTH_SECRET=replace-with-another-random-32-plus-character-string

# ──────────────────────────────────────────────────────────────
# 셀프호스팅 로컬 개발용 (docker-compose)
# ──────────────────────────────────────────────────────────────

# POSTGRES_PASSWORD=changeme
# WEB_URL=http://localhost:18100
# PUBLIC_API_URL=http://localhost:18101
