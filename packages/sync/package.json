{
  "name": "@mytool/sync",
  "version": "0.1.0",
  "description": "Claude Code skills/settings sync — scanner, bundler, masking. Library + CLI.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./scanner": {
      "types": "./src/lib/scanner.ts",
      "default": "./src/lib/scanner.ts"
    },
    "./bundle": {
      "types": "./src/lib/bundle.ts",
      "default": "./src/lib/bundle.ts"
    },
    "./mask": {
      "types": "./src/lib/mask.ts",
      "default": "./src/lib/mask.ts"
    },
    "./preset": {
      "types": "./src/lib/preset.ts",
      "default": "./src/lib/preset.ts"
    }
  },
  "bin": {
    "mytool-sync": "dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/cli.ts",
    "start": "tsx src/cli.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "archiver": "^7.0.1",
    "chalk": "^5.4.0",
    "commander": "^12.1.0",
    "yauzl": "^3.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/node": "^20.0.0",
    "@types/yauzl": "^2.10.3",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
