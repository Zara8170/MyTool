# 서버사이드 API 호출용 (Next.js Server Components)
API_URL=http://localhost:18101

# 클라이언트사이드 API URL (브라우저에서 직접 호출 시. 셀프호스팅 시 외부 도메인)
NEXT_PUBLIC_API_URL=http://localhost:18101

# PostgreSQL connection string (API 패키지와 동일한 DB)
DATABASE_URL=postgresql://mytool:mytool@localhost:5432/mytool

# JWT 서명용 비밀키 (API 패키지의 JWT_SECRET와 동일한 값)
JWT_SECRET=replace-with-same-value-as-api-JWT_SECRET
