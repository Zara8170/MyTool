// mytool — Prisma schema
//
// DATABASE_URL: 런타임용 (Supabase Supavisor pooler, port 6543)
// DIRECT_URL: 마이그레이션 전용 (Supabase direct connection, port 5432)
// 자체호스팅 시 DIRECT_URL을 생략하면 DATABASE_URL만 사용.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// 인증 / 조직
// ============================================================

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  name         String?
  avatarUrl    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  memberships  OrgMembership[]
  tokens       CliToken[]
  sessions     ClaudeSession[]
  events       Event[]
  usageRecords UsageRecord[]

  @@map("users")
}

enum Role {
  OWNER
  MEMBER
}

model Organization {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  members  OrgMembership[]
  projects Project[]

  @@map("organizations")
}

model OrgMembership {
  id        String       @id @default(cuid())
  userId    String
  orgId     String
  role      Role         @default(MEMBER)
  createdAt DateTime     @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
  @@map("org_memberships")
}

/// 토큰의 용도 — Web 세션은 7일, CLI 토큰은 1년 유효.
enum TokenKind {
  WEB
  CLI
}

model CliToken {
  id         String     @id @default(cuid())
  userId     String
  /// SHA-256(jwt) — 평문 토큰은 저장하지 않음
  tokenHash  String     @unique
  /// Web 세션 / CLI 토큰 구분
  kind       TokenKind  @default(WEB)
  /// 사용자 표시용 라벨
  label      String?
  /// 토큰이 마지막으로 사용된 시각 (분 단위로 throttle)
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime   @default(now())
  expiresAt  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, revokedAt])
  @@map("cli_tokens")
}

// ============================================================
// 프로젝트 / 세션 / 이벤트
// ============================================================

model Project {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// 4축 워크스페이스 토글 (integration-plan §0)
  /// Skills 축 — sync 페이지·기능 활성 여부
  syncEnabled    Boolean @default(true)
  /// Execution 축 — harness·PreToolUse 강제 활성 여부
  harnessEnabled Boolean @default(false)
  /// harness.yaml 의 캐시본 (web 에서 편집). 실제 파일은 사용자 PC.
  harnessConfig  Json?

  org          Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions     ClaudeSession[]
  events       Event[]
  usageRecords UsageRecord[]
  dailyStats   DailyProjectStats[]

  @@unique([orgId, slug])
  @@map("projects")
}

model ClaudeSession {
  id        String    @id
  projectId String
  userId    String
  startedAt DateTime
  endedAt   DateTime?

  createdAt DateTime  @default(now())

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  events       Event[]
  usageRecords UsageRecord[]
  messages     Message[]

  @@index([projectId, startedAt])
  @@index([userId])
  @@map("claude_sessions")
}

model Event {
  id              String    @id @default(cuid())
  projectId       String
  sessionId       String
  userId          String

  hookEventName    String
  toolName         String?
  toolInput        String?
  toolResponse     String?
  exitCode         Int?

  isSkillCall      Boolean   @default(false)
  skillName        String?
  isAgentCall      Boolean   @default(false)
  agentType        String?
  agentDesc        String?
  isSlashCommand   Boolean   @default(false)
  slashCommandName String?
  agentId          String?

  rawPayload       Json?

  timestamp        DateTime
  createdAt        DateTime  @default(now())

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session ClaudeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, timestamp])
  @@index([sessionId, timestamp])
  @@index([skillName])
  @@index([agentType])
  @@map("events")
}

model UsageRecord {
  id                       String   @id @default(cuid())
  projectId                String
  sessionId                String
  userId                   String

  model                    String
  inputTokens              Int
  outputTokens             Int
  cacheCreationInputTokens Int      @default(0)
  cacheReadInputTokens     Int      @default(0)
  estimatedCostUsd         Decimal  @db.Decimal(12, 6)

  isSubagent               Boolean  @default(false)
  recordedAt               DateTime
  createdAt                DateTime @default(now())

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  session ClaudeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, recordedAt])
  @@index([userId, recordedAt])
  @@map("usage_records")
}

model DailyProjectStats {
  id                  String   @id @default(cuid())
  projectId           String
  date                DateTime @db.Date

  sessionCount        Int      @default(0)
  activeUsers         Int      @default(0)
  inputTokens         BigInt   @default(0)
  outputTokens        BigInt   @default(0)
  cacheReadTokens     BigInt   @default(0)
  cacheCreationTokens BigInt   @default(0)
  estimatedCostUsd    Decimal  @default(0) @db.Decimal(14, 6)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, date])
  @@index([projectId, date])
  @@map("daily_project_stats")
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  orderIdx  Int
  timestamp DateTime
  createdAt DateTime @default(now())

  session ClaudeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, orderIdx])
  @@index([sessionId, orderIdx])
  @@map("messages")
}
